# Canonical browser-safe production origin. Use the stable Vercel production
# alias or custom HTTPS domain, with no path, query or fragment.
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# Server-only runtime connection. Use a restricted application role for normal
# evidence reads/writes. The erasure processor is exposed only through the
# request-scoped database function created by migrations.
STEMFORGE_DATABASE_URL=postgresql://stemforge_app:replace-me@127.0.0.1:5432/stemforge_development

# Privileged migration connection. Never expose either value through NEXT_PUBLIC_*.
STEMFORGE_DATABASE_MIGRATION_URL=postgresql://stemforge_migrator:replace-me@127.0.0.1:5432/stemforge_development

# Dedicated disposable database used only by explicit migration/integration commands.
STEMFORGE_TEST_DATABASE_URL=postgresql://stemforge_test:replace-me@127.0.0.1:5432/stemforge_remote_test

# Optional account UI. It stays hidden unless this server-controlled flag is exactly true
# and all three settings below are present. The publishable key is safe for browser use;
# never put a secret/service-role key in NEXT_PUBLIC_*.
STEMFORGE_AUTH_ENABLED=false
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace-me
STEMFORGE_AUTH_SITE_URL=https://your-project.vercel.app

# Optional explicit real-auth verification only. Use a permitted team test user;
# the runner creates its own disposable embedded database for import, sync and
# account-safety checks. These are never required by the ordinary gate.
STEMFORGE_AUTH_TEST_EMAIL=team-test-user@example.com
STEMFORGE_AUTH_TEST_PASSWORD=replace-with-test-only-password
STEMFORGE_ALLOW_REMOTE_TEST_DATABASE=0

# Optional internal beta operations. Both values are server-only and access fails
# closed unless the feature is explicitly enabled and every configured opaque owner
# ID is valid and matches a verified authenticated application owner.
STEMFORGE_INTERNAL_REPORTS_ENABLED=false
STEMFORGE_INTERNAL_REPORT_OWNER_IDS=

# Provider-managed/server-only release identity. Vercel supplies these; do not
# set NEXT_PUBLIC variants. STEMFORGE_BUILD_COMMIT is an optional non-Vercel fallback.
# VERCEL_ENV=production
# VERCEL_GIT_COMMIT_SHA=provider-managed
# STEMFORGE_BUILD_COMMIT=optional-server-only-commit

# Production smoke tests run from a trusted operator machine only. These are not
# production runtime variables and must not be configured in the hosted project.
STEMFORGE_PRODUCTION_BASE_URL=https://your-project.vercel.app
STEMFORGE_PRODUCTION_EXPECT_READY=true
