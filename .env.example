# Server-only runtime connection. Use a restricted INSERT/SELECT application role.
STEMFORGE_DATABASE_URL=postgresql://stemforge_app:replace-me@127.0.0.1:5432/stemforge_development

# Privileged migration connection. Never expose either value through NEXT_PUBLIC_*.
STEMFORGE_DATABASE_MIGRATION_URL=postgresql://stemforge_migrator:replace-me@127.0.0.1:5432/stemforge_development

# Dedicated disposable database used only by explicit migration/integration commands.
STEMFORGE_TEST_DATABASE_URL=postgresql://stemforge_test:replace-me@127.0.0.1:5432/stemforge_remote_test

