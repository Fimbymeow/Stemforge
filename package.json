{
    "name": "stemforge",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "pnpm run validate-content && next build",
        "start": "next start",
        "lint": "eslint .",
        "typecheck": "tsc --noEmit",
        "validate-content": "tsx scripts/validate-content.ts",
        "test:content": "tsx --test tests/content-validation.test.ts tests/content-version.test.ts",
        "test:content-version": "tsx --test tests/content-version.test.ts",
        "test:answers": "tsx --test tests/answer-engine.test.ts tests/question-submission-boundary.test.ts",
        "test:progress": "tsx --test tests/progress-payload.test.ts tests/progress-storage.test.ts tests/progress-calculations.test.ts tests/progress-migration.test.ts",
        "test:version-progress": "tsx --test tests/version-aware-progress.test.ts",
        "test:mastery": "tsx --test tests/mastery-model.test.ts",
        "test:completion": "tsx --test tests/completion-tracking.test.ts",
        "test:achievements": "tsx --test tests/achievements.test.ts",
        "test:merge": "tsx --test tests/merge.test.ts",
        "test:taxonomy": "tsx --test tests/taxonomy-runtime.test.ts",
        "test:question-bank": "tsx --test tests/question-bank-query.test.ts",
        "test:remote-evidence": "tsx --test tests/remote-evidence-validation.test.ts",
        "test:import": "tsx --test tests/progress-import.test.ts tests/authenticated-import.test.ts",
        "test:sync": "tsx --test tests/progress-sync.test.ts tests/authenticated-sync.test.ts",
        "test:account-safety": "tsx --test tests/evidence-provenance.test.ts tests/browser-data-controls.test.ts tests/account-data-export.test.ts",
        "test:beta-reports": "tsx --test tests/beta-reports.test.ts",
        "test:dashboard": "tsx --test tests/dashboard-derivations.test.ts",
        "test:graphs": "tsx --test tests/maths-expression.test.ts tests/maths-derivative.test.ts tests/graph-sampling.test.ts tests/graph-transformations.test.ts tests/function-analysis.test.ts tests/graph-answer-validation.test.ts",
        "test:practice": "tsx --test tests/practice-selection.test.ts tests/practice-storage-summary.test.ts",
        "test:auth": "tsx --test tests/auth-config.test.ts tests/auth-results.test.ts tests/owner-resolution.test.ts tests/reauthentication.test.ts",
        "test:database": "node --conditions=react-server --import tsx --test tests/remote-evidence-postgres.test.ts",
        "test:migration-scripts": "tsx --test tests/migration-command.test.ts",
        "db:migration:create": "node-pg-migrate create --migrations-dir migrations --migration-file-language js",
        "db:migrate": "tsx scripts/migrate-database.ts",
        "db:migrate:test": "tsx scripts/migrate-test-database.ts",
        "test": "pnpm run test:content && pnpm run test:taxonomy && pnpm run test:question-bank && pnpm run test:remote-evidence && pnpm run test:import && pnpm run test:sync && pnpm run test:account-safety && pnpm run test:beta-reports && pnpm run test:dashboard && pnpm run test:graphs && pnpm run test:practice && pnpm run test:auth && pnpm run test:migration-scripts && pnpm run test:answers && pnpm run test:progress && pnpm run test:version-progress && pnpm run test:mastery && pnpm run test:completion && pnpm run test:achievements && pnpm run test:merge",
        "test:e2e": "pnpm run test:e2e:ordinary && pnpm run test:e2e:auth-rendering",
        "test:e2e:ordinary": "tsx scripts/run-playwright-suite.ts",
        "test:e2e:auth-rendering": "tsx scripts/run-playwright-suite.ts --auth-enabled",
        "test:e2e:import:real": "tsx scripts/run-playwright-suite.ts --real-import",
        "test:e2e:sync:real": "tsx scripts/run-playwright-suite.ts --real-sync",
        "test:e2e:account-safety:real": "tsx scripts/run-playwright-suite.ts --real-account-safety",
        "test:e2e:desktop": "tsx scripts/run-playwright-suite.ts -- --project=desktop-chromium",
        "test:e2e:mobile": "tsx scripts/run-playwright-suite.ts -- --project=mobile-chromium",
        "test:e2e:completion": "tsx scripts/run-playwright-suite.ts -- completion-experience.spec.ts --project=desktop-chromium",
        "test:e2e:ui": "tsx scripts/run-playwright-suite.ts -- --ui",
        "test:all": "pnpm run typecheck && pnpm run lint && pnpm run validate-content && pnpm test && pnpm run build && pnpm run test:e2e"
    },
    "dependencies": {
        "@next/env": "15.5.20",
        "@supabase/ssr": "^0.12.0",
        "@supabase/supabase-js": "^2.110.3",
        "clsx": "^2.1.1",
        "katex": "^0.17.0",
        "lucide-react": "^0.468.0",
        "next": "^15.0.0",
        "pg": "^8.22.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-markdown": "^10.1.0",
        "rehype-katex": "^7.0.1",
        "remark-math": "^6.0.0",
        "server-only": "^0.0.1"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.5",
        "@playwright/test": "^1.61.1",
        "@types/node": "^22.10.0",
        "@types/pg": "^8.20.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "autoprefixer": "^10.4.20",
        "embedded-postgres": "17.10.0-beta.17",
        "eslint": "^9.16.0",
        "eslint-config-next": "^15.0.0",
        "node-pg-migrate": "^8.0.4",
        "postcss": "^8.4.49",
        "tailwindcss": "^3.4.16",
        "tsx": "^4.23.0",
        "typescript": "^5.7.0"
    }
}
